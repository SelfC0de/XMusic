<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_about"
    android:padding="24dp"
    android:minWidth="320dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настройки"
        android:textColor="#F0F0FF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Текущая версия"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvCurrentVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F0F0FF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvUpdateStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Актуально"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15FFFFFF"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/updateSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Доступно обновление"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvNewVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadUpdate"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="Скачать обновление"
            android:textSize="14sp"
            android:backgroundTint="#7C3AFF"
            style="@style/Widget.Material3.Button"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#15FFFFFF"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheckUpdate"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Проверить обновления"
        android:textSize="14sp"
        android:backgroundTint="#252540"
        android:textColor="#7C3AFF"
        style="@style/Widget.Material3.Button"/>

    <TextView
        android:id="@+id/tvCheckStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#55FFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15FFFFFF"
        android:layout_marginVertical="16dp"/>

    <TextView
        android:id="@+id/btnAboutApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="О приложении"
        android:textColor="#88FFFFFF"
        android:textSize="14sp"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/btnSettingsClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Закрыть"
        android:textColor="#55FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="12dp"
        android:layout_marginTop="8dp"/>

</LinearLayout>

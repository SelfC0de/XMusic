<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_track_item"
        android:paddingHorizontal="12dp">

        <!-- Cover -->
        <ImageView
            android:id="@+id/imgCover"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_cover"
            android:layout_marginEnd="12dp"/>

        <!-- Title/Artist -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F0F0FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#55FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Play button -->
        <ImageView
            android:id="@+id/btnPlay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/bg_btn_play"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"/>

        <!-- Download button -->
        <ImageView
            android:id="@+id/btnDownloadItem"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_download"
            android:background="@drawable/bg_btn_download"
            android:padding="8dp"
            android:scaleType="fitCenter"/>

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/cardRoot"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_track_item"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/imgPlaylistCover"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_cover"
            android:src="@drawable/ic_library"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlaylistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F0F0FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvTrackCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnDeletePlaylist"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_delete"
            android:padding="6dp"
            android:scaleType="fitCenter"/>

    </LinearLayout>

</LinearLayout>

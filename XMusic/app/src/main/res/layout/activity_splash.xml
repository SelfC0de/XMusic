<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View android:layout_width="match_parent" android:layout_height="220dp"
        android:background="@drawable/splash_gradient_top" android:layout_gravity="top"/>
    <View android:layout_width="match_parent" android:layout_height="220dp"
        android:background="@drawable/splash_gradient_bottom" android:layout_gravity="bottom"/>

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/selfcode_logo"
            android:scaleType="fitCenter"
            android:layout_marginBottom="28dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Self Music"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.06"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Self Music by SelfCode"
            android:textSize="13sp"
            android:textColor="#88FFFFFF"
            android:letterSpacing="0.03"/>

    </LinearLayout>

</FrameLayout>

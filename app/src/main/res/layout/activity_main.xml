<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Self Music"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_search"
                android:paddingHorizontal="14dp"
                android:hint="Поиск музыки..."
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearch"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:padding="0dp"
                app:icon="@android:drawable/ic_menu_search"
                app:iconSize="22dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                android:backgroundTint="@color/accent"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.Icon" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressSearch"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:indeterminate="true"
            android:progressTint="@color/accent"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tabTracks"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Треки"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:background="@drawable/bg_tab_selected" />

            <TextView
                android:id="@+id/tabLogs"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Логи"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:background="@drawable/bg_tab_normal" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="4dp" />

    <!-- Load more button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoadMore"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="4dp"
        android:text="Загрузить ещё"
        android:textSize="13sp"
        android:backgroundTint="@color/bg_card"
        android:textColor="@color/accent"
        app:strokeColor="@color/accent"
        app:strokeWidth="1dp"
        app:cornerRadius="10dp"
        android:visibility="gone"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <ScrollView
        android:id="@+id/scrollLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="@color/bg_dark"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#A0E0A0"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="Логи появятся после поиска..." />

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/downloadGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <ProgressBar
                android:id="@+id/progressDownload"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent"
                android:progressBackgroundTint="@color/bg_dark" />

            <TextView
                android:id="@+id/tvDownloadStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvSavePath"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Папка: Загрузки (по умолч.)"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickFolder"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Выбрать"
                android:textSize="11sp"
                android:paddingHorizontal="12dp"
                android:backgroundTint="@color/bg_dark"
                android:textColor="@color/accent"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="⬇  Скачать выбранный трек"
            android:textSize="14sp"
            android:backgroundTint="@color/accent"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>

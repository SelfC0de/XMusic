<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_about"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Новый плейлист"
        android:textColor="#F0F0FF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etPlaylistName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_search"
        android:paddingHorizontal="16dp"
        android:hint="Название плейлиста"
        android:textColor="#F0F0FF"
        android:textColorHint="#666688"
        android:textSize="15sp"
        android:singleLine="true"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

        <ImageView
            android:id="@+id/imgCoverPreview"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_cover"
            android:src="@drawable/ic_library"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/btnPickCover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выбрать обложку"
            android:textColor="#7C3AFF"
            android:textSize="14sp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="20dp">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отмена"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btnCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Создать"
            android:textColor="#7C3AFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="12dp"/>

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_about"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/selfcode_logo"
        android:scaleType="fitCenter"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Self Music"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by SelfCode"
        android:textSize="13sp"
        android:textColor="#7C3AFF"
        android:layout_marginBottom="20dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A45"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Developer"
        android:textSize="11sp"
        android:textColor="#55FFFFFF"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/linkTelegram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✈  t.me/selfcode_dev"
        android:textSize="14sp"
        android:textColor="#7C3AFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/linkVk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔵  vk.com/selfcode_dev"
        android:textSize="14sp"
        android:textColor="#7C3AFF"/>

</LinearLayout>
